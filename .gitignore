# Environment files — NEVER commit these
.env
.env.local
.env.production
backend/.env
frontend/.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.venv_train/
venv/
*.egg-info/

# ML Model files — FAISS index is small (746KB), safe to commit
*.bin
*.gguf
# Exclude FAISS files by default, but allow specific ones below
*.faiss
!backend/data/legal_index.faiss

# Database
*.db
*.sqlite
*.sqlite3
legal_gpt.db

# Node
node_modules/
frontend/node_modules/
npm-debug.log

# Logs
*.log
backend/logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test artifacts
test-results/
playwright-report/

